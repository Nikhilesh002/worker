# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require"

# Groq AI API Keys (pipe-separated for key rotation)
GROQ_API_KEYS="gsk_key1|gsk_key2|gsk_key3"

# Search API Keys (at least one required — tried in order: Brave > Tavily > Serper > Google)
BRAVE_API_KEY=""        # https://brave.com/search/api/ — 2,000 free/month
TAVILY_API_KEY=""       # https://tavily.com — 1,000 free/month
SERPER_API_KEY=""       # https://serper.dev — 2,500 free one-time
GOOGLE_SEARCH_API_KEY="" # https://console.cloud.google.com — 100 free/day
GOOGLE_SEARCH_CX=""     # Custom Search Engine ID

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_..."
CLERK_SECRET_KEY="sk_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
